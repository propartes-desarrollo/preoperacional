# ===========================
# Base de datos (PostgreSQL)
# ===========================
POSTGRES_USER=preoperacional_user
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DB=preoperacional_db
DATABASE_URL=postgresql://preoperacional_user:cambiar_en_produccion@base_de_datos_postgresql:5432/preoperacional_db

# ===========================
# Backend Node.js
# ===========================
NODE_ENV=development
PORT=3000
# Generar con: openssl rand -hex 32
JWT_SECRET=generar_con_openssl_rand_hex_32
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5176
CORS_ORIGIN=http://localhost:5176

# ===========================
# Frontend (Vite)
# ===========================
# URL que el NAVEGADOR usa para llamar al backend (no el contenedor)
VITE_API_URL=http://localhost:3006/api/v1
VITE_API_PROXY_TARGET=http://backend_node:3000

# ===========================
# Debug (solo desarrollo - NO activar en produccion)
# ===========================
ENABLE_DEBUG_ENDPOINTS=true

# ===========================
# Superadmin inicial (seed)
# ===========================
INITIAL_SUPERADMIN_EMAIL=tucorreo@dominio.com
INITIAL_SUPERADMIN_NAME=Nombre Apellido

# ===========================
# Almacenamiento de fotos
# ===========================
UPLOADS_DIR=/app/uploads
PHOTO_RETENTION_DAYS=90

# ===========================
# Resend (correos transaccionales y magic links)
# ===========================
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx
# Para pruebas usar el dominio de Resend: onboarding@resend.dev
# En produccion usar un dominio verificado: no-reply@tudominio.com
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_REPORT_EMAIL=admin@tudominio.com

# ===========================
# WhatsApp Cloud API (Meta)
# ===========================
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxx
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_TEMPLATE_NAME=alerta_inspeccion_pendiente
WHATSAPP_ADMIN_PHONE=573001234567

# ===========================
# Superadmin inicial (creado en seed)
# ===========================
INITIAL_SUPERADMIN_EMAIL=tucorreo@dominio.com
INITIAL_SUPERADMIN_NAME=Nombre Apellido

# ===========================
# Zona horaria
# ===========================
TZ=America/Bogota
