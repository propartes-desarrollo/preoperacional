# ============================================================
# DESARROLLO — valores para entorno local con Docker Compose
# ============================================================

# Base de datos (PostgreSQL)
POSTGRES_USER=preoperacional_user
POSTGRES_PASSWORD=cambiar_en_produccion
POSTGRES_DB=preoperacional_db
# DESARROLLO: el hostname es el nombre del servicio en docker-compose.yml
DATABASE_URL=postgresql://preoperacional_user:cambiar_en_produccion@base_de_datos_postgresql:5432/preoperacional_db

# Backend Node.js
NODE_ENV=development
PORT=3000
JWT_SECRET=generar_con_openssl_rand_hex_32   # openssl rand -hex 32
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:5176
CORS_ORIGIN=http://localhost:5176

# Frontend (Vite) — SOLO desarrollo
VITE_API_URL=http://localhost:3006/api/v1
VITE_API_PROXY_TARGET=http://backend_node:3000

# Debug — NO activar en produccion
ENABLE_DEBUG_ENDPOINTS=true

# Superadmin inicial (seed)
INITIAL_SUPERADMIN_EMAIL=tucorreo@dominio.com
INITIAL_SUPERADMIN_NAME=Nombre Apellido

# Almacenamiento de fotos
UPLOADS_DIR=/app/uploads
PHOTO_RETENTION_DAYS=90

# Resend (correos)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxx
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_REMINDER_TEMPLATE_NAME=recordatorio_preoperacional

# Zona horaria
TZ=America/Bogota


# ============================================================
# PRODUCCION — diferencias respecto al entorno de desarrollo
# ============================================================

# Base de datos: el hostname debe coincidir con el alias de red del compose
# DATABASE_URL=postgresql://preoperacional_user:PASSWORD_SEGURA@preoperacional_sst_db:5432/preoperacional_db

# Backend
# NODE_ENV=production
# APP_URL=https://preoperacional.propartes.com
# CORS_ORIGIN=https://preoperacional.propartes.com

# Frontend: URL publica del backend (la usa el navegador, no el contenedor)
# VITE_API_URL=https://preoperacional.propartes.com/api/v1
# VITE_API_PROXY_TARGET=http://preoperacional_sst_backend:3000

# Debug — desactivar en produccion
# ENABLE_DEBUG_ENDPOINTS=false

# Resend — usar dominio verificado
# RESEND_FROM_EMAIL=noresponder@propartes.com

# WhatsApp — token permanente de sistema (sin vencimiento)
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
